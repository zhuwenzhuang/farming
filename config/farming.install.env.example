# 在解包后的 release package 中，复制本文件为 config/farming.install.env。
# 大多数用户只需要修改 FARMING_INSTALL_DIR。

FARMING_INSTALL_DIR="${HOME}/farming"
FARMING_PORT=6694
FARMING_BASE_PATH=/farming

# 可选：把 Farming 配置和 token 文件放到安装目录之外。
# FARMING_CONFIG_DIR="${HOME}/.farming"

# 可选：为 demo 或共享机器隔离 server 进程的 HOME。
# FARMING_SERVER_HOME="${HOME}"

# 可选：启用应用内升级。默认不配置时不会检查或下载 GitHub release。
# manifest 可以声明 version 和 tarUrl；相对 tarUrl 会按 manifest URL 解析。
# FARMING_UPDATE_MANIFEST_URL="https://updates.example.com/farming/manifest.json"
# FARMING_UPDATE_ASSET_BASE_URL="https://updates.example.com/farming/"
# FARMING_UPDATE_AUTH_TOKEN=""

# 可选：app bundle 默认自带 glibc 2.28 tarball；这里仅用于复用已有 runtime。
# FARMING_USE_GLIBC=auto
# FARMING_GLIBC_ROOT="${HOME}/.farming/glibc228"

# 可选：按 cgroup / 系统内存自动计算 Node heap；设置为 0 表示使用 Node 默认值。
# FARMING_NODE_MAX_OLD_SPACE_SIZE=auto
