# 复制本文件为 config/farming.deploy.env。
# 大多数用户只需要修改 FARMING_REMOTE。

FARMING_REMOTE=user@linux-host
FARMING_REMOTE_DIR=/home/user/farming
FARMING_REMOTE_PORT=6694
FARMING_REMOTE_BASE_PATH=/farming

# 可选：为 demo 或共享服务器隔离 Farming 配置和 agent 历史。
# FARMING_REMOTE_CONFIG_DIR=/home/user/.farming
# FARMING_REMOTE_SERVER_HOME=/home/user

# 可选：为远端实例启用应用内升级。默认不配置时不会检查或下载 GitHub release。
# manifest 可以声明 version 和 tarUrl；相对 tarUrl 会按 manifest URL 解析。
# FARMING_REMOTE_UPDATE_MANIFEST_URL=https://updates.example.com/farming/manifest.json
# FARMING_REMOTE_UPDATE_ASSET_BASE_URL=https://updates.example.com/farming/
# FARMING_REMOTE_UPDATE_AUTH_TOKEN=

# 可选：在 CentOS 7 / glibc 2.17 机器上复用已有 glibc 2.28 runtime。
# 默认会尝试使用 FARMING_REMOTE_DIR 旁边的 glibc228 目录。
# FARMING_REMOTE_USE_GLIBC=auto
# FARMING_REMOTE_GLIBC_ROOT=/home/user/glibc228
