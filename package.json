{
  "name": "farming-code",
  "version": "2.2.8",
  "description": "Remote browser workspace for supervising AI coding agents",
  "main": "backend/server.js",
  "bin": {
    "farming": "bin/farming"
  },
  "files": [
    "backend/*.js",
    "backend/acp/",
    "backend/data/",
    "bin/",
    "config/*.example",
    "dist/",
    "frontend/*.js",
    "frontend/farming-net/",
    "frontend/skins/",
    "frontend/themes/",
    "frontend/vendor/ghostty-web/",
    "scripts/sync-ghostty-vendor.js",
    "LICENSE",
    "README.md",
    "README.zh_cn.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md",
    "index.html"
  ],
  "scripts": {
    "sync:ghostty-vendor": "node scripts/sync-ghostty-vendor.js",
    "postinstall": "node scripts/sync-ghostty-vendor.js",
    "prepack": "FARMING_BASE_PATH=/farming npm run build",
    "start": "npm run build && node backend/server.js",
    "start:net": "node backend/farming-net-server.js",
    "start:no-auth": "FARMING_DISABLE_AUTH=1 npm start",
    "dev:backend": "node backend/server.js",
    "dev:frontend": "vite",
    "dev": "node backend/server.js & vite --open & wait",
    "build": "vite build",
    "deploy:remote": "./scripts/deploy.sh up",
    "deploy:remote:no-auth": "./scripts/deploy.sh up --disable-auth",
    "release:cli": "./scripts/package-cli-release.sh",
    "release:cli:all": "FARMING_CLI_TARGETS=${FARMING_CLI_TARGETS:-node22-macos-arm64,node22-linux-x64} ./scripts/package-cli-release.sh",
    "release:cli:smoke": "./scripts/smoke-cli-release.sh",
    "release:npm:smoke": "./scripts/smoke-npm-package.sh",
    "release:app": "./scripts/package-release.sh",
    "release:app:linux-compat": "./scripts/package-linux-compat-release.sh",
    "release:app:legacy-linux": "./scripts/package-linux-legacy-release.sh",
    "release:tarball": "./scripts/package-release.sh",
    "release:remote": "./scripts/install-remote-release.sh",
    "release:remote:linux-compat": "./scripts/install-remote-linux-compat-release.sh",
    "docs:product:screenshots": "node scripts/capture-product-screenshots.js",
    "test": "node scripts/run-tests.js",
    "test:codex-app-server:real": "FARMING_REAL_CODEX_APP_SERVER_SMOKE=1 node scripts/smoke-codex-app-server.js",
    "test:update:platforms": "node scripts/test-update-platforms.js",
    "test:e2e": "npm run test:e2e:playwright",
    "test:e2e:playwright": "playwright test",
    "test:e2e:playwright:update": "playwright test --update-snapshots",
    "test:e2e:legacy": "npm run test:e2e:local",
    "test:e2e:local": "FARMING_BASE_PATH=/farming npm run build && node scripts/e2e.js local",
    "test:e2e:remote": "FARMING_BASE_PATH=/farming npm run build && node scripts/e2e.js remote",
    "test:remote-terminal:smoke": "node scripts/smoke-remote-terminal.js",
    "test:e2e:workspaces:local": "FARMING_BASE_PATH=/farming npm run build && node scripts/e2e-workspaces.js local",
    "test:e2e:workspaces:remote": "FARMING_BASE_PATH=/farming npm run build && node scripts/e2e-workspaces.js remote",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 \"backend/**/*.js\" \"frontend/**/*.js\" \"scripts/**/*.js\" bin/farming --ignore-pattern \"frontend/vendor/**\" --ignore-pattern \"frontend/themes/**\"",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "keywords": [
    "ai-agent",
    "coding-agent",
    "codex",
    "claude",
    "remote-workspace",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhuwenzhuang/farming.git"
  },
  "bugs": {
    "url": "https://github.com/zhuwenzhuang/farming/issues"
  },
  "homepage": "https://github.com/zhuwenzhuang/farming#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.58.1",
    "@agentclientprotocol/codex-acp": "1.1.2",
    "@agentclientprotocol/sdk": "1.2.1",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "chokidar": "^5.0.0",
    "diff": "^9.0.0",
    "express": "^4.18.2",
    "ghostty-web": "^0.4.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "material-icon-theme": "^5.36.1",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.2.0-beta.12",
    "qrcode-generator": "^2.0.4",
    "react": "^19.2.4",
    "react-arborist": "^3.10.5",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "ripgrep": "^0.3.1",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@yao-pkg/pkg": "6.20.0",
    "esbuild": "^0.27.7",
    "eslint": "^10.2.0",
    "puppeteer": "^24.40.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "overrides": {
    "qs": "6.15.3",
    "dompurify": "3.4.11"
  }
}
